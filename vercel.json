{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/css/(.*)",
      "destination": "/public/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/public/js/$1"
    },
    {
      "source": "/favicon.svg",
      "destination": "/public/favicon.svg"
    },
    {
      "source": "/std/:std_id",
      "destination": "/api/index?std_id=:std_id"
    },
    {
      "source": "/api/preview/:std_id",
      "destination": "/api/index?std_id=:std_id&format=json"
    }
  ]
}
